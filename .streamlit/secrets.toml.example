# Copia este archivo a `.streamlit/secrets.toml` y completa los valores.
# secrets.toml esta en .gitignore (no se commitea).

[supabase]
url = "https://TU-PROYECTO.supabase.co"
# service_role key (server-side; NO la anon key). Settings -> API en Supabase.
service_key = "eyJ..."
table = "mediciones"

[app]
# Hash SHA-256 del PIN de edicion. Generar con:
#   python -c "import hashlib;print(hashlib.sha256('TU_PIN'.encode()).hexdigest())"
pin_hash = "..."
# Secreto para firmar la cookie de sesion (string aleatorio largo).
cookie_secret = "cambia-esto-por-algo-aleatorio-largo"
cookie_days = 365
cookie_name = "hidropal_auth"

# Opcional: respaldo del CSV a una rama de GitHub (boton manual).
# [github]
# GITHUB_TOKEN = "ghp_..."
# GITHUB_REPO = "AndresPaladino/hidropal"
# GITHUB_BRANCH = "data"
# GITHUB_DATA_PATH = "datos_pozo.csv"
